// Firebase Security Rules
// Firestoreコンソール（https://console.firebase.google.com）で設定してください
// プロジェクト設定 > Firestore Database > ルール タブで以下を貼り付け
//
// ⚠️ 重要: 下の ALLOWED_UIDS に家族全員のUIDを入れてから「公開」してください。
//    空のままだと全員アクセス不可になります（＝ロックアウト）。
//    UIDの調べ方は末尾の「設定手順」を参照。

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== ヘルパー関数 ====================

    // このアプリのデータにアクセスを許可する家族メンバーのUID一覧
    // ↓↓↓ ここに実際のUIDを貼り付けてください（匿名UIDは使わないこと） ↓↓↓
    function allowedUids() {
      return [
        'ここにあなたのUIDを貼り付け',
        'ここに家族のUIDを貼り付け'
      ];
    }

    // 家族メンバーとして許可されたユーザーかチェック
    // - ログイン済みであること
    // - 匿名ログインではないこと（Googleログインのみ許可）
    // - UIDが allowedUids() に含まれること
    function isFamilyMember() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.auth.uid in allowedUids();
    }

    // ==================== 家計簿データ ====================

    // budgetMonths: 月別の予算データ（budgetMonths/YYYY-MM）
    match /budgetMonths/{monthId} {
      allow read, write: if isFamilyMember();
    }

    // budgetData: CSVインポート学習ルール、旧形式データ（移行元）等
    match /budgetData/{document} {
      allow read, write: if isFamilyMember();
    }

    // ==================== カレンダー関連 ====================

    match /holidayUsers/{userId} {
      allow read, write: if isFamilyMember();
    }

    match /holidays/{holidayId} {
      allow read, write: if isFamilyMember();
    }

    match /calendarMemos/{memoId} {
      allow read, write: if isFamilyMember();
    }

    // ==================== 買い物リスト ====================

    match /shoppingItems/{itemId} {
      allow read, write: if isFamilyMember();
    }

    match /shoppingTemplates/{templateId} {
      allow read, write: if isFamilyMember();
    }

    // ==================== それ以外は全拒否 ====================
    // 明示的にデフォルト拒否（新しいコレクションを追加したら上に許可を書くこと）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/*
==================== 設定手順 ====================

1. 家族全員のUIDを調べる
   方法A（アプリから）:
     - アプリでGoogleログインする
     - 右上メニュー（☰）を開くと、名前の下に「ID: xxxxx」が表示される
     - タップするとUIDがコピーされる
   方法B（Firebase Consoleから）:
     - Firebase Console > Authentication > Users タブ
     - 各ユーザーの「ユーザーUID」列の値をコピー

2. 上の allowedUids() に全員のUIDを貼り付ける
   例:
     return [
       'aBcD1234EfGh5678IjKl9012MnOp',
       'qRsT3456UvWx7890YzAb1234CdEf'
     ];

3. Firebase Console > Firestore Database > ルール タブに
   このファイルの内容を貼り付けて「公開」

==================== 匿名（ゲスト）ログインの無効化 ====================

匿名ログインは全データを誰でも読み書きできる穴になるため、無効化してください:

1. Firebase Console > Authentication > Sign-in method
2. 「匿名」を選択 > 「無効にする」> 保存
3. 「Google」は有効のままにする

（アプリ側でもゲストログインボタンは削除済みです）

==================== 注意事項 ====================

- allowedUids() が空、または自分のUIDを入れ忘れると
  自分自身もアクセスできなくなります（データは消えません。UIDを直せば復旧）。
- 家族が増えたら allowedUids() にUIDを追加して再度「公開」してください。

*/
